#========================================
# Capstone Project - Production ENV
# For Dokploy on Raspberry Pi
#========================================

#--- PostgreSQL Database ---
DB_HOST=your-pi-ip-or-hostname
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=capstone

#--- Required API Keys ---
TYPHOON_API_KEY=your-typhoon-api-key
GOOGLE_CSE_ID=your-google-cse-id
GOOGLE_API_KEY=your-google-api-key

#--- LLM Configuration ---
LLM_MODEL=typhoon-v1.5x-70b-instruct
MODEL_BASE_URL=https://api.opentyphoon.ai/v1
MODEL_PROVIDER=openai
TEMPERATURE=0.5
EMBEDDING_MODEL=bge-m3

#--- Frontend ---
# Use /api since nginx proxies /api/* to the backend
VITE_API_URL=/api

#--- Optional ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key

#--- Logging ---
LOG_LEVEL=INFO
